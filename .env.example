# =============================================================================
# Agentic AI Enterprise Lab
# Copy to .env and adjust values:  cp .env.example .env
#
# NETWORKING RULE
#   - Containers (Spring, FastAPI, n8n, etc.) → use INTERNAL hostnames below
#   - Your Mac (browser, curl)              → use localhost:<port>
# =============================================================================

# General
TZ=America/New_York

# -----------------------------------------------------------------------------
# Internal service URLs — use these inside containers on agentic-ai-network
# Do NOT use localhost in Spring Boot, FastAPI, or n8n HTTP nodes.
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_INTERNAL_PORT=5432
REDIS_HOST=redis
REDIS_INTERNAL_PORT=6379
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_URL=http://minio:9001
N8N_INTERNAL_URL=http://n8n:5678
SPRING_AI_URL=http://spring-ai:8080
FASTAPI_URL=http://fast-api:8000

# Spring Boot (Phase 2) — JDBC uses internal hostname
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/agentic_ai

# -----------------------------------------------------------------------------
# PostgreSQL
# Internal: postgres:5432  |  Browser/tools on Mac: localhost:5432
# -----------------------------------------------------------------------------
POSTGRES_USER=agentic_admin
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=agentic_ai
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# pgAdmin
# Host (your Mac): localhost:5050
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me_pgadmin
PGADMIN_PORT=5050

# -----------------------------------------------------------------------------
# Redis
# Host (containers): redis:6379
# Host (your Mac):   localhost:6379
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Qdrant
# Host (containers): qdrant:6333
# Host (your Mac):   localhost:6333
# -----------------------------------------------------------------------------
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# -----------------------------------------------------------------------------
# MinIO
# API  (containers): minio:9000
# API  (your Mac):   localhost:9000
# Console (your Mac): localhost:9001
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=agentic_minio
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET_DOCUMENTS=documents
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# n8n — PostgreSQL persistence (NOT SQLite)
# Connects to agentic_ai database on postgres:5432 via agentic-ai-network
# Tables: workflow_entity, credentials_entity, execution_entity, ...
# N8N_HOST / N8N_WEBHOOK_URL are for browser access only — keep as localhost
# -----------------------------------------------------------------------------
N8N_PORT=5678
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_DB_NAME=agentic_ai
N8N_DB_USER=n8n_user
N8N_DB_PASSWORD=change_me_n8n

# Phase 2 / 3 ports (host access only)
SPRING_PORT=8080
FASTAPI_PORT=8000

# -----------------------------------------------------------------------------
# AWS Bedrock (Phase 2 — Spring AI)
# Credentials from your AWS account; Bedrock model access must be enabled
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# HTTP Basic auth for the chat audit trail (/api/v1/chat/sessions/**)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin
